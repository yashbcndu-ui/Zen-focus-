{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile and focus goals.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "streak": { "type": "integer" },
        "totalPoints": { "type": "integer" },
        "dailyFocusLimit": { "type": "integer" },
        "lastLoggedAt": { "type": "string", "format": "date-time" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "biggestStruggle": { "type": "string" },
        "blockedApps": { "type": "array", "items": { "type": "string" } },
        "appLimits": { "type": "object", "additionalProperties": { "type": "integer" } }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "FocusSession": {
      "title": "Focus Session",
      "description": "Deep work or meditation sessions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deep_work", "meditation", "digital_detox"] },
        "duration": { "type": "integer", "description": "Duration in minutes" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "duration", "startTime"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/focusSessions/{sessionId}": {
      "schema": "FocusSession",
      "description": "Focus and meditation sessions."
    }
  }
}
